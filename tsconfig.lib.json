{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/artifacts",
    "rootDir": "src"
  },
  "include": [
    "src/component/**/*",
    "src/component/language/react/**/*",
    "src/component/language/vue/**/*",
    "src/component/language/angular/**/*"
  ]
}